/* MARK: - Info Alert (खेल की जानकारी) */
"info_title" = "खेल की जानकारी";
"alert_button_ok" = "ठीक है";
"info_body" = "ऑटेस्टमी में आपका स्वागत है!\n\nइस खेल में, विभिन्न आकृतियाँ, अक्षर या संख्याएँ प्रदर्शित की जाती हैं।\nआपका काम यह याद रखना है कि आपने प्रत्येक आइटम को कितनी बार देखा है।\n\nखेल के प्रकार:\n• आकृतियाँ – वृत्त, वर्ग, रेखाएँ, आदि।\n• अक्षर – यादृच्छिक बड़े अक्षर (A से Z)\n• संख्याएँ – यादृच्छिक संख्याएँ (0 से 9)\n\nसेटिंग्स:\n• खेल की अवधि – खेल कितनी देर तक चलता है\n• गति – आइटम कितनी तेजी से दिखाई देते हैं\n• आइटम की संख्या – आकृतियों के लिए: कितनी अलग-अलग आकृतियाँ; अक्षरों/संख्याओं के लिए: कितने अलग-अलग विकल्पों में से चुना जाता है\n• रंग मोड – प्रति आइटम निश्चित रंग या यादृच्छिक रंग।";

"info_crypto_title" = "क्रिप्टो पुरस्कार";
"info_crypto_explanation" = "ऑटेस्टमी ऐप खिलाड़ियों को AUteste टोकन से पुरस्कृत करने के लिए Polygon Mainnet ब्लॉकचेन का उपयोग करता है। आपके पास दो विकल्प हैं:\n\n1. मेरा वॉलेट: पुरस्कार सीधे आपके व्यक्तिगत वॉलेट पते पर भेजा जाता है।\n2. खेल खजाना: पुरस्कार ऐप के केंद्रीय खजाने में जाता है। इस तरह, आप एक बड़े संयुक्त पुरस्कार पूल के लिए बचत करते हैं।\n\nअपनी पसंद बनाने के लिए दाएं से बाएं स्वाइप करें। आपका पता एक वैध Polygon Mainnet पता होना चाहिए।";

